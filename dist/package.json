{
  "name": "@deebeetech/is-helper",
  "version": "5.0.0",
  "description": "A collection of \"is\"-style helpers to help solidify if something \"is\" something else. Has no dependencies and uses only raw JavaScript methodology.",
  "homepage": "https://github.com/deebee-tech/is-helper",
  "license": "MIT",
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deebee-tech/is-helper.git"
  },
  "type": "module",
  "main": "index.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      }
    }
  },
  "types": "index.d.mts",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "is",
    "helper",
    "type",
    "type guard",
    "type-guard",
    "check",
    "checkers",
    "type-check",
    "type-checker",
    "type-checkers",
    "type-checking"
  ]
}
